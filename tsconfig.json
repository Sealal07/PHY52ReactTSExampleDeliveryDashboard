{
  "compilerOptions": {
    "target": "es2025",
    "lib": ["ES2025", "DOM", "DOM.Iterable"],
    "module": "esnext", 
    "moduleResolution": "bundler", 
    "allowImportingTsExtensions": true, 
    "isolatedModules": true,
    "noEmit": true, 
    "jsx": "react-jsx",

    // СТРОГИЙ КОНТРОЛЬ КОДА
    "strict": true, // полный набор строгих проверок типов
    "noImplicitAny": true, //запрет неявного присвоения типа any при невозможности вывода
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noUnusedParameters": true,
    "noUnusedLocals": true, 
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    // установка абсолютных путей 
    "baseUrl": ".",
    "paths": {
      "@/*":["src/*"]
    }
  },
  "references": [{ "path": "./tsconfig.node.json" }],
  "include": ["src"]
}
